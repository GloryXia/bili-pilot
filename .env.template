# Bilibili 登录态
BILI_COOKIE=SESSDATA=你的SESSDATA; bili_jct=你的bili_jct; DedeUserID=你的UID
BILI_UID=你的UID

# LLM 服务商 (zhipu, kimi, minimax)
LLM_PROVIDER=zhipu

# 智谱 GLM
ZHIPU_API_KEY=你的智谱API_KEY
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-4.7

# 月之暗面 Kimi
KIMI_API_KEY=你的KIMI_API_KEY
KIMI_BASE_URL=https://api.moonshot.cn/v1/
KIMI_MODEL=moonshot-v1-8k

# MiniMax 稀宇科技
MINIMAX_API_KEY=你的MINIMAX_API_KEY
MINIMAX_BASE_URL=https://api.minimax.chat/v1/
MINIMAX_MODEL=abab6.5s-chat

# 风险最低的推荐开关
DRY_RUN=true
MOVE_MODE=false
FORCE_RECLASSIFY=false

# 更保守的速度
PAGE_SIZE=20
REQUEST_MIN_DELAY_MS=2500
REQUEST_MAX_DELAY_MS=4500
TAG_WRITE_DELAY_MS=5000
MAX_VIDEO_SAMPLES=5
SAVE_EVERY_N=1

# 请求失败时的小重试
MAX_RETRIES=2
RETRY_BASE_DELAY_MS=3000
