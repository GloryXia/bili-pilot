{
  "manifest_version": 3,
  "name": "BiliPilot — 哔哩智能管家",
  "version": "2.0.0",
  "description": "B 站个人数据智能管理：关注自动分组、收藏自动归类、稍后再看摘要、观看历史画像",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "notifications",
    "cookies",
    "scripting"
  ],

  "host_permissions": [
    "*://*.bilibili.com/*",
    "*://bilibili.com/*",
    "https://api.bilibili.com/*",
    "https://open.bigmodel.cn/*",
    "https://api.moonshot.cn/*",
    "https://api.minimax.chat/*"
  ],

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["content/bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["content/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "BiliPilot 哔哩智能管家"
  }
}
